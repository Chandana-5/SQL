CREATE TABLE Branch (
    branch_id INT PRIMARY KEY AUTO_INCREMENT, 
    branch_name VARCHAR(50), 
    mgr_id INT, 
    mgr_start_date DATE, -- Fixed typo: 'mger_stat_date'
    FOREIGN KEY (mgr_id) REFERENCES Employee(emp_id) ON DELETE SET NULL 
);
