CREATE TABLE Employee (
    emp_id INT PRIMARY KEY AUTO_INCREMENT, 
    first_name VARCHAR(20), 
    last_name VARCHAR(20), 
    birth_date DATE, 
    sex VARCHAR(1), 
    salary INT, 
    super_id INT, 
    branch_id INT 
);
